# --- Database (Postgres) ---
# On Vercel, this is auto-populated when you add a Neon / Vercel Postgres
# integration. Locally for dev, point it at a local Postgres or a Neon
# dev branch. Example:
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# --- Authentication ---
# Generate with:  openssl rand -base64 48
JWT_SECRET="replace-me-with-a-long-random-string"

# --- Vercel Blob (file storage) ---
# On Vercel, this is auto-injected when you add Blob storage to the project.
# Locally, copy the value from your Vercel project -> Storage -> Blob -> ".env.local" tab.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxxxxxxxxxx"

# --- App URL ---
# Used for share links / embed snippets. Set to your production domain in prod.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
